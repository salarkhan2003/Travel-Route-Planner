{
  "expo": {
    "name": "Roamio",
    "slug": "roamio",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "roamio",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./logo/Roamio_logo.png",
    "splash": {
      "image": "./logo/Roamio_logo.png",
      "backgroundColor": "#E8F5E9",
      "resizeMode": "contain"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./logo/Roamio_logo.png",
        "backgroundColor": "#E8F5E9"
      },
      "package": "com.roamio.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.roamio.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Roamio uses your location to show nearby destinations and provide navigation.",
        "NSLocationAlwaysUsageDescription": "Roamio uses your location for navigation."
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Roamio to use your location for navigation and nearby suggestions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "93e49509-6e2e-4e2d-8975-558e3a74d18e"
      }
    }
  }
}
