{
  "expo": {
    "name": "Roamio",
    "slug": "roamio",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "roamio",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./logo/ROAMIO_LOGO-NEW.png",
    "splash": {
      "image": "./logo/ROAMIO_LOGO-NEW.png",
      "backgroundColor": "#E8F5E9",
      "resizeMode": "contain"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./logo/ROAMIO_LOGO-NEW.png",
        "backgroundColor": "#E8F5E9"
      },
      "package": "com.roamio.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "READ_SMS",
        "RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.roamio.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Roamio uses your location to show nearby destinations and provide navigation.",
        "NSLocationAlwaysUsageDescription": "Roamio uses your location for navigation."
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Roamio to use your location for navigation and nearby suggestions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "67565551-a6b8-46ab-8d7c-cd1c342fa265"
      }
    },
    "owner": "psalarkhan09"
  }
}
